{
    "name": "bekunika/debug-loggers",
    "description": "Laravel package for console route and SQL debug logging.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "debug",
        "logging",
        "sql",
        "routes"
    ],
    "autoload": {
        "psr-4": {
            "Eventapo\\DebugLoggers\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eventapo\\DebugLoggers\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Eventapo\\DebugLoggers\\DebugLoggersServiceProvider"
            ]
        }
    },
    "require": {
        "php": "^8.2",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "symfony/console": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "scripts": {
        "test": "phpunit",
        "format": "pint"
    }
}
